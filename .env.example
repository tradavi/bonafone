# Base de données
# Dev : SQLite local — DATABASE_URL="file:./dev.db"
# Prod : PostgreSQL — DATABASE_URL="postgresql://user:pass@host:5432/db"
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth v5) — `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"` pour générer un secret
AUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"

# Chiffrement-at-rest des clés API stockées en DB (Stripe/Brevo/Twilio/OAuth/...)
# Sans cette variable, les clés sont stockées en clair (mode dev OK, prod NON).
# Génère 32 octets : `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# Accepte aussi base64 (44 chars) ou phrase libre (dérivée par scrypt).
# ⚠ Ne JAMAIS changer cette clé après que des secrets ont été chiffrés — sinon
#   les valeurs deviennent illisibles. Sauvegardez-la dans un secret manager.
SECRETS_ENCRYPTION_KEY=""

# OAuth providers (vides = boutons "Continuer avec…" masqués sur /connexion)
# Google : https://console.cloud.google.com/ → OAuth client ID (web)
#   Authorized redirect URI : ${AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Facebook : https://developers.facebook.com/apps/ → Facebook Login (web)
#   Valid OAuth redirect URI : ${AUTH_URL}/api/auth/callback/facebook
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""

# Stripe
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Google APIs
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACE_ID=""

# Facebook Graph API
FB_PAGE_ID=""
FB_ACCESS_TOKEN=""

# Email (Brevo)
BREVO_API_KEY=""
BREVO_FROM_EMAIL="contact@example.com"

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# Cloudinary (uploads photos)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Web Push (notifications navigateur — admin temps réel)
# Générer une paire VAPID : `npx web-push generate-vapid-keys --json`
# La clé publique est exposée au client pour souscrire ; la privée signe les envois.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@example.com"

# Coordonnées magasin (affichées sur le site)
NEXT_PUBLIC_STORE_NAME="Bonafone"
NEXT_PUBLIC_STORE_TAGLINE="L'expert en réparation"
NEXT_PUBLIC_STORE_PHONE="+32 2 347 36 62"
NEXT_PUBLIC_STORE_EMAIL="info@bonafone.com"
NEXT_PUBLIC_STORE_ADDRESS="Chaussée d'Alsemberg 742, 1180 Uccle, Belgique"
NEXT_PUBLIC_STORE_HOURS="Lun-Sam 10h-18h30"
NEXT_PUBLIC_STORE_WHATSAPP="+32477000000"
NEXT_PUBLIC_STORE_GMAPS="https://maps.google.com/?q=Chauss%C3%A9e+d'Alsemberg+742+1180+Uccle"
